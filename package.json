{
  "name": "@kuneosu/dep-clean",
  "version": "1.1.2",
  "description": "CLI tool to find and delete dependency/cache directories like node_modules, venv, __pycache__",
  "type": "module",
  "main": "./dist/electron/main.js",
  "bin": {
    "dep-clean": "./dist/bin/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:renderer",
    "build:core": "tsc -p tsconfig.json",
    "build:renderer": "vite build --config gui/vite.config.ts",
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:core\" \"npm:dev:electron\"",
    "dev:renderer": "vite --config gui/vite.config.ts",
    "dev:core": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "dev:electron": "wait-on tcp:5173 dist/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist/electron/main.js",
    "dev:cli": "tsx bin/cli.ts",
    "start": "node dist/bin/cli.js",
    "start:gui": "electron dist/electron/main.js",
    "clean": "rimraf dist",
    "test": "tsx --test test/**/*.test.ts",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux"
  },
  "keywords": [
    "cli",
    "cleanup",
    "node_modules",
    "venv",
    "cache",
    "dependency"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^4.0.1",
    "commander": "^12.1.0",
    "inquirer": "^9.2.23",
    "ora": "^8.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.14.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "rimraf": "^6.0.1",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vite": "^6.3.5",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.kuneosu.depclean.gui",
    "productName": "dep-clean-gui",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "electron/assets"
    },
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
